# 部署后请在 Vercel 项目 Settings → Environment Variables 中配置
# 用于 RSS 链接、Open Graph 等，填你的线上完整地址（含 https://）

NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Notion 游戏日常数据库（无头 CMS）
# 格式用等号 =，不要用冒号。真实密钥请写在 .env 或 .env.local 中
# NOTION_API_KEY=secret_xxx
# NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

